{
  "name": "figma-inspect-cli",
  "version": "0.2.0",
  "description": "Small CLI for inspecting Figma API resources.",
  "type": "module",
  "bin": {
    "figma-inspect": "dist/bin/figma-inspect.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/bin/figma-inspect.js",
    "start": "node ./dist/bin/figma-inspect.js",
    "dev": "tsx ./src/bin/figma-inspect.ts",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check . && knip && npm run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --pool=forks --maxWorkers=1",
    "knip": "knip",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^3.2.4",
    "knip": "6.16.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
